{
  "name": "sherpa-guardrails",
  "version": "0.1.0",
  "private": true,
  "description": "Smart-contract-backed spend controls for autonomous AI agents on Arc.",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "api:dev": "pnpm --filter @sherpa/api dev",
    "api:test": "pnpm --filter @sherpa/api test",
    "intent:test": "pnpm --filter @sherpa/intent test",
    "x402:test": "pnpm --filter @sherpa/x402 test",
    "wallets:demo": "tsx scripts/create-demo-wallets.ts",
    "arc:check": "tsx scripts/check-arc.ts",
    "live:ready": "tsx scripts/live-readiness.ts",
    "testnet:status": "tsx scripts/testnet-status.ts",
    "testnet:deploy": "forge script packages/contracts/script/DeployArc.s.sol:DeployArc --root packages/contracts --rpc-url arc_testnet --broadcast",
    "testnet:configure": "forge script packages/contracts/script/ConfigureDemo.s.sol:ConfigureDemo --root packages/contracts --rpc-url arc_testnet --broadcast",
    "testnet:fund": "bash -lc 'set -a; source .env; set +a; cast send \"$ARC_USDC_ADDRESS\" \"transfer(address,uint256)\" \"$SPEND_ACCOUNT_ADDRESS\" \"$DEMO_FUND_AMOUNT_BASE_UNITS\" --rpc-url \"$ARC_TESTNET_RPC_URL\" --private-key \"$DEPLOYER_PRIVATE_KEY\"'",
    "testnet:agent": "bash -lc 'set -a; source .env; set +a; pnpm --filter sherpa-demo-agent start'",
    "testnet:dashboard": "bash -lc 'set -a; source .env; set +a; pnpm --filter sherpa-dashboard dev'",
    "contracts:build": "forge build --root packages/contracts",
    "contracts:test": "forge test --root packages/contracts",
    "contracts:coverage": "forge coverage --root packages/contracts"
  },
  "keywords": [
    "ai-agents",
    "usdc",
    "arc",
    "smart-contracts",
    "spend-controls"
  ],
  "author": "gnanam (@gnanam1990)",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.25",
    "dotenv": "^16.4.7",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0",
    "viem": "^2.41.2"
  },
  "packageManager": "pnpm@9.15.9"
}
